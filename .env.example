# --- Database ---
# Local dev (docker-compose): postgresql://cryptohacker:cryptohacker@localhost:5432/cryptohacker
DATABASE_URL="postgresql://cryptohacker:cryptohacker@localhost:5432/cryptohacker"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (optional, https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Razorpay (https://dashboard.razorpay.com/app/keys) ---
# Only these three values need to be pasted in. Everything else (plans, webhook
# handling, lifecycle) is wired up automatically once these are set.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Public key exposed to the browser checkout widget — keep identical to RAZORPAY_KEY_ID
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- First admin bootstrap ---
# The user with this email is promoted to ADMIN automatically on seed/first login.
ADMIN_EMAIL="admin@cryptohacker.dev"
